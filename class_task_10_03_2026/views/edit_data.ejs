
<%- include('layouts/header.ejs') %>

    <div class="container">
        <div class="row justify-content-center mt-5 py-5">
            <div class="col-8">
                <form action="/update/data/<%=data._id %>" method="post" class="border-0">
                    <div class="row p-3 bg-light-blue rounded-4">
                        <h2 class="lead fw-normal fs-3 text-capitalize">Edit Password</h2>
                        <hr class="mt-2">
                        <div class="mb-4">
                            <label for="update_password" class="form-label fs-5">Update Password</label>
                            <input type="password" class="form-control form-control-lg" name="password" placeholder="Password must be at least 6 characters" name="password" required>
                        </div>
                        <hr class="mt-2">
                        <div class="col-12 mb-2">
                            <button type="submit" class="btn btn-lg btn-primary fs-4 w-100">Update Password</button>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>