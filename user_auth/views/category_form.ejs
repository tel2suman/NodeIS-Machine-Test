
<%- include('layouts/header') %>

    <div class="container col-xl-10 col-xxl-8 px-4 py-5">
        <div class="row align-items-center g-lg-5 py-5">
            <div class="col-lg-12 text-center text-lg-center">
                <h1 class="display-4 fw-bold lh-1 text-body-emphasis mb-3">Vertically hero sign-up form</h1>
            </div>
            <div class="col-md-10 mx-auto col-lg-7">
                <form action="/create/category" class="p-4 border rounded-3 bg-light" method="post">
                    <h3 class="text-center fs-4 mb-4 fw-semibold">Enter Product Category Here</h3>
                    <div class="form-floating mb-3">
                        <input type="text" class="form-control form-control-lg" name="categoryName" placeholder="Product Category" required>
                        <label for="floatingInput">Product Category</label>
                    </div>
                    <button class="w-100 btn btn-lg btn-primary" type="submit">Submit</button>
                </form>
            </div>
        </div>
    </div>

